<?xml version="1.0" encoding="utf-8" ?>
<Controls:CustomControl xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:Controls="clr-namespace:Cardrly.Controls"
             xmlns:res="clr-namespace:Cardrly.Resources.Lan"
             x:Class="Cardrly.Pages.Security_WarningPage"
             Title="Security_WarningPage">
    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Margin="20">
        <Image>
            <Image.Source>
                <FontImageSource Glyph="" FontFamily="FontIconSolid" Color="Gray" Size="150"></FontImageSource>
            </Image.Source>
        </Image>
        <Label Text="{x:Static res:AppResources.lblAccessDenied}"
               FontSize="28"
               TextColor="Black"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

        <Label x:Name="lblWar"
               FontSize="18"
               TextColor="Black" HorizontalTextAlignment="Center"
               HorizontalOptions="CenterAndExpand"/>
    </VerticalStackLayout>
</Controls:CustomControl>